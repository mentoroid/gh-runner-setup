# GitHub Actions Multi-Runner Configuration
# Copy this file and edit for your environment

# GitHub repository or organization URL
GITHUB_URL="https://github.com/YOUR_ORG/YOUR_REPO"

# Number of runners to create (including runner-01)
NUM_RUNNERS=6

# Runner name prefix (runners will be named: PREFIX-01, PREFIX-02, etc.)
RUNNER_NAME_PREFIX="runner"

# Runner labels (comma-separated)
RUNNER_LABELS="self-hosted,linux,x64"

# User to run the runners as (will be created if it doesn't exist)
RUNNER_USER="github-runner"

# Base directory for runner installations
RUNNER_BASE_DIR="/opt"

# Runner version (leave empty to auto-detect latest)
RUNNER_VERSION=""

# Resource limits per runner (systemd cgroup controls)
# CPUQuota: percentage of CPU cores (400% = 4 cores)
CPU_QUOTA_PER_RUNNER="400%"
# Memory high watermark (soft limit, triggers reclaim pressure)
MEMORY_HIGH="4G"
# Memory hard limit (OOM kills if exceeded)
MEMORY_MAX="5G"
# Max swap per runner
MEMORY_SWAP_MAX="2G"
# Nice value (higher = lower priority, 0-19)
NICE_VALUE=5
# Max tasks/threads per runner
TASKS_MAX=512

# Combined slice limits (for ALL runners together)
# Adjust based on your total cores/RAM minus headroom for OS
SLICE_CPU_QUOTA="2000%"
SLICE_MEMORY_MAX="24G"
SLICE_MEMORY_HIGH="22G"

# Docker configuration
INSTALL_DOCKER=true
DOCKER_LOG_MAX_SIZE="10m"
DOCKER_LOG_MAX_FILES=3

# Pre-install tools
INSTALL_CLAUDE_CODE=true
INSTALL_BUN=true

# Maintenance timer
ENABLE_MAINTENANCE_TIMER=true
# Cron schedule for maintenance (systemd OnCalendar format)
MAINTENANCE_SCHEDULE="Sun *-*-* 02:00:00"
